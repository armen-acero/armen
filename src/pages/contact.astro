---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";
---

<Layout
  title={`Contact | ${SITE.brand}`}
  description="Get in touch with Armen Andonian about AI automation, search and AI visibility, or to book an AI Opportunity Audit. I reply personally, usually within one working day."
>
  <!-- NAV -->
  <header class="absolute inset-x-0 top-0 z-30">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
      <a href="/" class="flex items-center text-white">
        <img src="/logo.png" alt={SITE.brand} class="h-12 w-auto sm:h-14" />
      </a>
      <div class="hidden items-center gap-8 text-sm font-medium text-white/70 md:flex">
        <a href="/#audit" class="transition hover:text-white">The Audit</a>
        <a href="/#process" class="transition hover:text-white">Process</a>
        <a href="/search-visibility" class="transition hover:text-white">Search &amp; Visibility</a>
        <a href="/#faq" class="transition hover:text-white">FAQ</a>
      </div>
      <a
        href={SITE.bookingUrl.startsWith("#") ? `/${SITE.bookingUrl}` : SITE.bookingUrl}
        class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-ink shadow-lg shadow-black/20 transition hover:bg-white/90"
        >Book the audit</a
      >
    </nav>
  </header>

  <!-- HERO + FORM -->
  <section id="top" class="glow relative overflow-hidden bg-ink">
    <div class="relative mx-auto max-w-3xl px-6 pb-20 pt-36 md:pb-28 md:pt-44">
      <div class="text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-accent">Contact</p>
        <h1 class="mt-4 text-4xl font-extrabold leading-tight tracking-tight text-white md:text-6xl">
          Let's <span class="gradient-text">talk</span>.
        </h1>
        <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/70">
          Tell me a little about your business and what you're hoping to automate
          or grow. I read and reply to every message personally, usually within one
          working day.
        </p>
      </div>

      <!-- Form card -->
      <div class="mt-12 rounded-3xl border border-white/10 bg-white p-6 shadow-2xl shadow-black/30 md:p-10">
        <form id="contact-form">
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <label for="c-name" class="block text-sm font-semibold text-ink">Name</label>
              <input
                id="c-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                placeholder="Your name"
                class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-ink outline-none transition focus:border-brand focus:ring-2 focus:ring-brand/20"
              />
            </div>
            <div>
              <label for="c-email" class="block text-sm font-semibold text-ink">Email</label>
              <input
                id="c-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                placeholder="you@company.com"
                class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-ink outline-none transition focus:border-brand focus:ring-2 focus:ring-brand/20"
              />
            </div>
          </div>

          <div class="mt-5">
            <label for="c-company" class="block text-sm font-semibold text-ink">
              Company <span class="font-normal text-slate-400">(optional)</span>
            </label>
            <input
              id="c-company"
              name="company"
              type="text"
              autocomplete="organization"
              placeholder="Your company"
              class="mt-2 w-full rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-ink outline-none transition focus:border-brand focus:ring-2 focus:ring-brand/20"
            />
          </div>

          <div class="mt-5">
            <label for="c-message" class="block text-sm font-semibold text-ink">How can I help?</label>
            <textarea
              id="c-message"
              name="message"
              required
              rows="5"
              placeholder="A few lines about your business and what you'd like to automate or improve."
              class="mt-2 w-full resize-y rounded-xl border border-slate-300 bg-white px-4 py-3 text-sm text-ink outline-none transition focus:border-brand focus:ring-2 focus:ring-brand/20"
            ></textarea>
          </div>

          <!-- honeypot -->
          <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" />

          <button
            type="submit"
            id="contact-submit"
            class="mt-6 inline-flex w-full items-center justify-center gap-2 rounded-full bg-gradient-to-r from-brand to-brand-bright px-6 py-3.5 text-sm font-semibold text-white shadow-lg shadow-brand/20 transition hover:opacity-95 disabled:opacity-60 sm:w-auto"
          >
            Send message
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </button>
          <p id="contact-error" class="mt-3 hidden text-sm text-red-600"></p>
        </form>

        <!-- success state -->
        <div id="contact-success" class="hidden text-center">
          <div class="mx-auto grid h-14 w-14 place-items-center rounded-full bg-brand/10 text-brand">
            <svg class="h-7 w-7" viewBox="0 0 24 24" fill="none"><path d="M5 13l4 4L19 7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </div>
          <p class="mt-4 text-xl font-bold text-ink">Message sent, thank you.</p>
          <p class="mx-auto mt-2 max-w-md text-slate-600">
            I've got your message and I'll get back to you personally, usually
            within one working day. Want to skip ahead and grab a time?
          </p>
          <a
            href={SITE.bookingUrl.startsWith("#") ? `/${SITE.bookingUrl}` : SITE.bookingUrl}
            class="mt-5 inline-flex items-center justify-center gap-2 rounded-full bg-ink px-6 py-3 text-sm font-semibold text-white transition hover:bg-ink-soft"
          >
            Book your AI Opportunity Audit
            <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
          </a>
        </div>
      </div>

      <p class="mt-6 text-center text-sm text-white/50">
        Prefer email? Reach me at
        <a href={`mailto:${SITE.email}`} class="font-medium text-white/80 underline underline-offset-4 transition hover:text-white">{SITE.email}</a>
      </p>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-ink-soft py-12 text-white/60">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 sm:flex-row">
      <div class="flex items-center text-white">
        <div>
          <img src="/logo.png" alt={SITE.brand} class="h-12 w-auto" />
          <p class="mt-2 text-xs leading-tight text-white/50">{SITE.role}</p>
        </div>
      </div>
      <nav class="flex gap-6 text-sm">
        <a href="/#audit" class="transition hover:text-white">The Audit</a>
        <a href="/search-visibility" class="transition hover:text-white">Search &amp; Visibility</a>
        <a href="/#faq" class="transition hover:text-white">FAQ</a>
        <a href="/contact" class="transition hover:text-white">Contact</a>
      </nav>
    </div>
    <p class="mt-8 text-center text-xs text-white/40">
      © {new Date().getFullYear()} {SITE.brand}. {SITE.location}.
    </p>
  </footer>

  <script define:vars={{ web3formsKey: SITE.web3formsKey }}>
    const form = document.getElementById("contact-form");
    const submitBtn = document.getElementById("contact-submit");
    const errorEl = document.getElementById("contact-error");

    form.addEventListener("submit", async (e) => {
      e.preventDefault();
      errorEl.classList.add("hidden");

      const name = form.name.value.trim();
      const email = form.email.value.trim();
      const company = form.company.value.trim();
      const message = form.message.value.trim();
      if (!name || !email || !message) return;

      if (!web3formsKey) {
        // No key configured: fall back to a mailto so the message is never lost.
        const body = encodeURIComponent(
          `Name: ${name}\nEmail: ${email}\nCompany: ${company}\n\n${message}`
        );
        window.location.href = `mailto:${"hello@armenandonian.com"}?subject=${encodeURIComponent(
          "Website enquiry from " + name
        )}&body=${body}`;
        return;
      }

      submitBtn.disabled = true;
      submitBtn.textContent = "Sending...";

      try {
        const res = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          headers: { "Content-Type": "application/json", Accept: "application/json" },
          body: JSON.stringify({
            access_key: web3formsKey,
            subject: `New enquiry from ${name}`,
            from_name: "armenandonian.com contact form",
            email, // becomes the reply-to so you can reply directly
            name,
            company: company || "(not provided)",
            message,
            botcheck: "",
          }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data.success) throw new Error(data.message || "Send failed");

        form.classList.add("hidden");
        document.getElementById("contact-success").classList.remove("hidden");
      } catch (err) {
        submitBtn.disabled = false;
        submitBtn.textContent = "Send message";
        errorEl.textContent =
          "Something went wrong sending your message. Please email hello@armenandonian.com directly.";
        errorEl.classList.remove("hidden");
      }
    });
  </script>
</Layout>
