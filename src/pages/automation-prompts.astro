---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

// 25 practical prompts, grouped. These are the "lead magnet" — genuinely useful
// on their own, and they double as an SEO asset.
const groups = [
  {
    name: "Email & inbox",
    prompts: [
      "Draft a reply to this email that politely declines but keeps the door open. Match my tone using these two past emails: [paste].",
      "Summarise this email thread into 3 bullet points and list every action I need to take, with deadlines.",
      "Turn these rough notes into a professional follow-up email to a client: [paste notes].",
      "Read this inbox export (CSV) and flag the 10 emails most likely to need a same-day reply, with a one-line reason for each.",
      "Write 3 subject-line options for this email and tell me which is most likely to get opened, and why.",
    ],
  },
  {
    name: "Admin & data",
    prompts: [
      "Clean this messy spreadsheet: standardise the date formats, split full names into first and last, and flag any duplicate rows.",
      "Write me a script that watches a folder and renames every new invoice to 'YYYY-MM-DD_supplier_amount.pdf'.",
      "Compare these two CSV exports and tell me which rows are new, which changed, and which were removed.",
      "Build a weekly summary that pulls the totals from this sheet and writes them up in plain English for my team.",
      "Reconcile this list of payments against this list of invoices and show me anything that doesn't match.",
    ],
  },
  {
    name: "Documents",
    prompts: [
      "Read this contract and pull out the key terms: parties, dates, value, notice period, and any auto-renewal clauses.",
      "Extract every line item from these invoice PDFs into a single, tidy spreadsheet.",
      "Turn this long report into a one-page executive summary for a non-technical reader.",
      "Read this client intake form and draft a structured client record I can drop into my CRM.",
      "Convert this scanned document into clean, editable text and fix the obvious scanning errors.",
    ],
  },
  {
    name: "Content & marketing",
    prompts: [
      "Take this blog post and repurpose it into 5 LinkedIn posts and 5 short captions, in my brand voice.",
      "Write 10 FAQ answers for my website based on these real support emails: [paste].",
      "Draft a month of social posts from these 3 case studies, each with a hook and a call to action.",
      "Rewrite this product description to rank for the keyword '[keyword]' without sounding stuffed or robotic.",
      "Turn this customer testimonial into a short case study with a headline and three result bullets.",
    ],
  },
  {
    name: "Customer & sales",
    prompts: [
      "Draft clear replies to these 15 common customer questions so I can paste them into a help doc.",
      "Score these inbound leads from 1 to 5 based on [your criteria] and tell me who to call first.",
      "Write a polite 3-email chase sequence for an overdue invoice that stays friendly but firm.",
      "Summarise this sales call transcript into next steps and short notes for the CRM.",
      "Draft a personalised outreach email to each of these 10 prospects using their company details: [paste].",
    ],
  },
];

const totalPrompts = groups.reduce((n, g) => n + g.prompts.length, 0);
---

<Layout
  title={`${totalPrompts} Free Claude Prompts to Automate Your Admin | ${SITE.brand}`}
  description={`A free pack of ${totalPrompts} ready-to-use prompts for automating email, admin, documents, marketing and sales with Claude. Copy, paste, and put hours back in your week.`}
>
  <!-- NAV -->
  <header class="absolute inset-x-0 top-0 z-30">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
      <a href="/" class="flex items-center text-white">
        <img src="/logo.png" alt={SITE.brand} class="h-12 w-auto sm:h-14" />
      </a>
      <div class="hidden items-center gap-8 text-sm font-medium text-white/70 md:flex">
        <a href="/#audit" class="transition hover:text-white">The Audit</a>
        <a href="/#process" class="transition hover:text-white">Process</a>
        <a href="/search-visibility" class="transition hover:text-white">Search Visibility</a>
        <a href="/#faq" class="transition hover:text-white">FAQ</a>
      </div>
      <a
        href={SITE.bookingUrl}
        class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-ink shadow-lg shadow-black/20 transition hover:bg-white/90"
        >Book the audit</a
      >
    </nav>
  </header>

  <!-- HERO -->
  <section id="top" class="glow relative overflow-hidden bg-ink">
    <div class="relative mx-auto max-w-3xl px-6 pb-20 pt-36 text-center md:pb-24 md:pt-44">
      <span
        class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-medium text-white/80 backdrop-blur"
      >
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        Free prompt pack
      </span>
      <h1 class="mt-6 text-4xl font-extrabold leading-[1.05] tracking-tight text-white sm:text-5xl">
        {totalPrompts} prompts to <span class="gradient-text">automate your admin</span>
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-lg leading-relaxed text-white/70">
        These are the same kinds of prompts I use with Claude to take repetitive
        work off a business's plate. Copy any of them, swap in your details, and
        put hours back in your week. No sign-up needed.
      </p>

      <!-- email capture (optional, soft) -->
      <form id="lead-form" class="mx-auto mt-9 max-w-md rounded-2xl border border-white/10 bg-white/5 p-5 text-left backdrop-blur">
        <p class="text-sm font-semibold text-white">Want new prompts as I publish them?</p>
        <div class="mt-3 flex flex-col gap-3 sm:flex-row">
          <input
            id="email-input"
            name="email_address"
            type="email"
            required
            placeholder="you@company.com"
            class="w-full flex-1 rounded-full border border-white/15 bg-ink/40 px-5 py-3 text-sm text-white placeholder-white/40 outline-none transition focus:border-accent focus:ring-2 focus:ring-accent/20"
          />
          <button
            type="submit"
            class="inline-flex items-center justify-center rounded-full bg-gradient-to-r from-brand-bright to-accent px-6 py-3 text-sm font-semibold text-ink transition hover:opacity-95"
          >
            Notify me
          </button>
        </div>
        <p id="lead-success" class="mt-2 hidden text-xs text-accent">Thanks — you're on the list.</p>
        <p id="lead-hint" class="mt-2 text-xs text-white/40">No spam. Unsubscribe anytime.</p>
      </form>
    </div>
  </section>

  <!-- PROMPTS -->
  <section class="mx-auto max-w-4xl px-6 py-20 md:py-28">
    <div class="space-y-14">
      {
        groups.map((g) => (
          <div>
            <h2 class="text-sm font-semibold uppercase tracking-widest text-brand">{g.name}</h2>
            <div class="mt-5 space-y-3">
              {g.prompts.map((p) => (
                <div class="group flex items-start gap-4 rounded-2xl border border-slate-200 bg-white p-5 transition hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5">
                  <p class="prompt-text flex-1 leading-relaxed text-slate-700">{p}</p>
                  <button
                    type="button"
                    class="copy-btn flex-none rounded-full border border-slate-200 bg-slate-50 px-3 py-1.5 text-xs font-semibold text-slate-500 transition hover:border-brand/40 hover:text-brand"
                    aria-label="Copy prompt"
                  >
                    Copy
                  </button>
                </div>
              ))}
            </div>
          </div>
        ))
      }
    </div>
  </section>

  <!-- CTA -->
  <section class="glow relative overflow-hidden bg-ink py-24 md:py-32">
    <div class="relative mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-white md:text-5xl">
        Want these set up <span class="gradient-text">in your business?</span>
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/70">
        Prompts are the start. In the AI Opportunity Audit we find the highest-impact
        processes to automate, build one live, and you leave with a plan to keep going.
      </p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
        <a
          href={SITE.bookingUrl}
          class="inline-flex items-center gap-2 rounded-full bg-white px-7 py-3.5 text-base font-semibold text-ink shadow-xl shadow-black/20 transition hover:bg-white/90"
        >
          Book your AI Opportunity Audit
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/ai-scorecard" class="text-sm font-semibold text-white/70 transition hover:text-white">
          Or take the free Scorecard &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-ink-soft py-12 text-white/60">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 sm:flex-row">
      <div class="flex items-center text-white">
        <div>
          <img src="/logo.png" alt={SITE.brand} class="h-12 w-auto" />
          <p class="mt-2 text-xs leading-tight text-white/50">{SITE.role}</p>
        </div>
      </div>
      <nav class="flex gap-6 text-sm">
        <a href="/#audit" class="transition hover:text-white">The Audit</a>
        <a href="/ai-scorecard" class="transition hover:text-white">Scorecard</a>
        <a href="/search-visibility" class="transition hover:text-white">Search &amp; Visibility</a>
        <a href={`mailto:${SITE.email}`} class="transition hover:text-white">Contact</a>
      </nav>
    </div>
    <p class="mt-8 text-center text-xs text-white/40">
      © {new Date().getFullYear()} {SITE.brand}. {SITE.location}.
    </p>
  </footer>

  <script define:vars={{ formAction: SITE.emailFormAction }}>
    // Copy buttons
    document.querySelectorAll(".copy-btn").forEach((btn) => {
      btn.addEventListener("click", async () => {
        const text = btn.parentElement.querySelector(".prompt-text").textContent.trim();
        try {
          await navigator.clipboard.writeText(text);
        } catch (_) {
          const ta = document.createElement("textarea");
          ta.value = text;
          document.body.appendChild(ta);
          ta.select();
          document.execCommand("copy");
          document.body.removeChild(ta);
        }
        const original = btn.textContent;
        btn.textContent = "Copied";
        btn.classList.add("text-brand", "border-brand/40");
        setTimeout(() => {
          btn.textContent = original;
        }, 1500);
      });
    });

    // Soft email capture
    const leadForm = document.getElementById("lead-form");
    if (leadForm) {
      leadForm.addEventListener("submit", async (e) => {
        e.preventDefault();
        const email = document.getElementById("email-input").value.trim();
        if (!email) return;
        if (formAction) {
          try {
            const fd = new FormData();
            fd.append("email_address", email);
            await fetch(formAction, { method: "POST", body: fd, mode: "no-cors" });
          } catch (_) {}
        }
        document.getElementById("email-input").value = "";
        document.getElementById("lead-hint").classList.add("hidden");
        document.getElementById("lead-success").classList.remove("hidden");
      });
    }
  </script>
</Layout>
