---
import Layout from "../layouts/Layout.astro";
import { SITE } from "../config";

const services = [
  {
    title: "Search Optimization",
    desc: "Show on the search engines where your customers are already looking. Technical fixes, on-page optimisation and a content strategy that earns durable organic traffic, month after month.",
  },
  {
    title: "AI visibility",
    desc: "Be the name AI recommends. I make sure ChatGPT, Google's AI answers and other assistants surface and cite your business when people ask for what you do.",
  },
  {
    title: "Link building & digital PR",
    desc: "Be the authority that search engines and AI tools trust. Genuine, relevant links and press coverage that lift your whole domain, not spammy shortcuts that get penalised.",
  },
  {
    title: "Content strategy",
    desc: "Turn content into pipeline. The topics, formats and cadence that attract the right people, build trust, and quietly do your selling for you.",
  },
];

const points = [
  "A growth background, not just a checklist of tactics",
  "Search and AI visibility treated as one job, not two",
  "Clear reporting tied to leads and revenue, not vanity metrics",
  "The same automation thinking, so your marketing runs leaner",
];

const faqs = [
  {
    q: "What's the difference between SEO and 'AI visibility'?",
    a: "SEO gets you found on search engines like Google. AI visibility gets you found <em>inside AI answers</em>: when someone asks ChatGPT, Gemini or Google's AI overview for a recommendation, your business is the one that gets named and cited. The two overlap heavily, so I work on them together rather than treating them as separate projects.",
  },
  {
    q: "How long until I see results?",
    a: "AI visibility can move fast, sometimes within weeks, because AI tools surface fresh, well-structured content quickly. Traditional organic search is slower and compounding: meaningful movement typically shows in 2 to 3 months, with the biggest gains landing around 4 to 6 months. I'll give you realistic timelines for your specific situation up front, never inflated promises.",
  },
  {
    q: "Do you guarantee first-page rankings?",
    a: "No one credible can guarantee a specific ranking, and anyone who does is a red flag. What I guarantee is a clear strategy, honest reporting, and steady, durable progress tied to leads and revenue rather than vanity positions. The goal is customers, not screenshots of rankings.",
  },
  {
    q: "How do I actually get recommended by ChatGPT and other AI tools?",
    a: "AI tools cite sources they can read, trust and verify. That means clean, well-structured content, strong topical authority, genuine third-party mentions and the right technical signals so assistants can confidently surface you. I make your business the easy, safe answer for an AI to give.",
  },
  {
    q: "Will this work for my industry?",
    a: "In almost every case, yes. If your customers search Google or ask an AI tool for what you do, locally or globally, there's visibility to be won. I'll tell you honestly during our first conversation if I don't think the opportunity is there, rather than take you on regardless.",
  },
  {
    q: "How do you report on progress?",
    a: "Clear monthly reports tied to outcomes that matter: visibility, qualified traffic, leads and revenue, not a wall of metrics no one acts on. We also jump on a call every two weeks so you always know what I'm working on, why, and what it's producing.",
  },
  {
    q: "Can you handle both my search visibility and my automation?",
    a: `Yes, that's the whole point. I bring the same automation thinking to your marketing so it runs leaner, and pair it with your search and AI visibility. If you're curious about the automation side, start with the <a href="/" class="text-brand underline underline-offset-2">AI Opportunity Audit</a>.`,
  },
];

// FAQ structured data (rich-result eligible). Strip HTML for the plain-text answers.
const faqJsonLd = JSON.stringify({
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map((f) => ({
    "@type": "Question",
    name: f.q,
    acceptedAnswer: {
      "@type": "Answer",
      text: f.a.replace(/<[^>]+>/g, ""),
    },
  })),
});

const testimonials = [
  { quote: "Their consultancy and guidance have been invaluable in helping us refine and optimise our SEO strategies.", name: "Maria Georgieva", company: "Payhawk" },
  { quote: "Within a relatively short time, we saw great improvements in website traffic and visibility.", name: "Angelina Sarycheva", company: "Oxa Life" },
  { quote: "They do what they claim. Refreshing to work with a team who actually gets stuff done!", name: "Enzo Belen", company: "Master Ventures" },
  { quote: "Thanks to their expertise, I've been able to be on the first page of Google.", name: "Ian Mulholland Dean", company: "Spouse Visa Lawyers" },
  { quote: "They are true professionals, and I would highly recommend them to anyone.", name: "Aneesh Medina", company: "PAID Network" },
  { quote: "We have worked with them since 2018, and will continue to do so for the future.", name: "Dave Vasoodaven", company: "Gulbenkian Andonian" },
  { quote: "They were able to bring our website back on track on the search engine. Communication was seamless throughout.", name: "Red Team Partners", company: "Red Team Partners" },
  { quote: "They not only assisted in building a robust SEO strategy but also went above and beyond.", name: "Rababe Zeghdani", company: "Oasis Crystalized" },
  { quote: "Amazing SEO service! No complaints. Just let them handle it for you.", name: "Hagop Sarkissian", company: "CL Lawyers" },
  { quote: "They have consistently delivered on their promises. Highly recommend them.", name: "Charles Andreo", company: "Oxa Life" },
  { quote: "5 star SEO service. Learned a lot from these guys during the time I worked with them.", name: "Alex Theubolt", company: "Sponsor Licence Lawyers" },
  { quote: "Highly recommend their audits to anyone looking to boost SEO on their website.", name: "Alex Overmyer", company: "Independent" },
];
---

<Layout
  title={`Search & AI Visibility | ${SITE.brand}`}
  description="Get found by the people, and the AI, looking for you. Search marketing, AI visibility, link building, digital PR and content strategy that brings a steady flow of the right customers."
>
  <!-- NAV -->
  <header class="absolute inset-x-0 top-0 z-30">
    <nav class="mx-auto flex max-w-6xl items-center justify-between px-6 py-5">
      <a href="/" class="flex items-center text-white">
        <img src="/logo.png" alt={SITE.brand} class="h-12 w-auto sm:h-14" />
      </a>
      <div class="hidden items-center gap-8 text-sm font-medium text-white/70 md:flex">
        <a href="/#audit" class="transition hover:text-white">The Audit</a>
        <a href="/#process" class="transition hover:text-white">Process</a>
        <a href="/#why" class="transition hover:text-white">Why me</a>
        <a href="/contact" class="transition hover:text-white">Contact</a>
      </div>
      <a
        href="/contact"
        class="rounded-full bg-white px-5 py-2.5 text-sm font-semibold text-ink shadow-lg shadow-black/20 transition hover:bg-white/90"
        >Send me a message</a
      >
    </nav>
  </header>

  <!-- HERO -->
  <section id="top" class="glow relative overflow-hidden bg-ink">
    <div class="relative mx-auto max-w-4xl px-6 pb-20 pt-36 text-center md:pb-28 md:pt-44">
      <div class="flex flex-wrap items-center justify-center gap-2">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-medium text-white/80 backdrop-blur"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
          Search &amp; Visibility
        </span>
        <a
          href="/"
          class="group inline-flex items-center gap-2 rounded-full border border-white/15 bg-white/5 px-4 py-1.5 text-xs font-medium text-white/80 backdrop-blur transition hover:border-accent/50 hover:bg-white/10 hover:text-white"
        >
          <span class="h-1.5 w-1.5 rounded-full bg-brand-bright"></span>
          AI Opportunity Audit
          <svg class="h-3 w-3 transition group-hover:translate-x-0.5" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
      </div>
      <h1 class="mt-6 text-4xl font-extrabold leading-tight tracking-tight text-white md:text-6xl">
        Get found by the people, <span class="gradient-text">and the AI</span>, looking for you.
      </h1>
      <p class="mx-auto mt-6 max-w-2xl text-lg leading-relaxed text-white/70">
        Automation makes your business run leaner. Visibility makes it grow. I help
        you become the name that gets recommended across Google and AI tools like
        ChatGPT, so the right customers find you first.
      </p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-full bg-gradient-to-r from-brand to-brand-bright px-7 py-3.5 text-base font-semibold text-white shadow-xl shadow-brand/20 transition hover:opacity-95"
        >
          Send me a message
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/" class="text-sm font-semibold text-white/70 transition hover:text-white">
          Or book an AI Opportunity Audit &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- SERVICES -->
  <section class="mx-auto max-w-6xl px-6 py-20 md:py-28">
    <div class="max-w-2xl">
      <p class="text-sm font-semibold uppercase tracking-widest text-brand">What I do</p>
      <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl">
        Four levers that make you easier to find and harder to ignore.
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-slate-600">
        They work best together: search and AI visibility get you seen, links and
        PR build the authority behind it, and content gives all of it something
        worth ranking.
      </p>
    </div>
    <div class="mt-12 grid gap-4 sm:grid-cols-2">
      {
        services.map((s) => (
          <div class="group rounded-2xl border border-slate-200 bg-white p-7 transition hover:border-brand/40 hover:shadow-lg hover:shadow-brand/5">
            <div class="mb-4 grid h-11 w-11 place-items-center rounded-xl bg-brand/10 text-brand transition group-hover:bg-brand group-hover:text-white">
              <svg class="h-5 w-5" viewBox="0 0 20 20" fill="none">
                <path d="M5 11l3 3 7-9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
            <h3 class="text-xl font-semibold text-ink">{s.title}</h3>
            <p class="mt-2 leading-relaxed text-slate-500">{s.desc}</p>
          </div>
        ))
      }
    </div>
  </section>

  <!-- WHY ME -->
  <section class="border-t border-slate-200 bg-white">
    <div class="mx-auto max-w-6xl px-6 py-20 md:py-28">
      <div class="grid items-center gap-12 lg:grid-cols-5">
        <div class="lg:col-span-2">
          <p class="text-sm font-semibold uppercase tracking-widest text-brand">Why me</p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl">
            Visibility that's tied to growth, not guesswork.
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-slate-600">
            I've spent years helping businesses get found and grow. AI has changed
            where people search, not the fundamentals of earning their trust.
          </p>
        </div>
        <div class="lg:col-span-3">
          <ul class="grid gap-4 sm:grid-cols-2">
            {
              points.map((p) => (
                <li class="flex items-start gap-3.5 rounded-2xl border border-slate-200 bg-slate-50 p-5">
                  <span class="mt-0.5 grid h-7 w-7 flex-none place-items-center rounded-full bg-brand/10 text-brand">
                    <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none">
                      <path d="M3 8.5l3 3 7-7" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                  </span>
                  <span class="text-slate-700">{p}</span>
                </li>
              ))
            }
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- TESTIMONIALS -->
  <section id="testimonials" class="border-t border-slate-200 bg-slate-50 py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand">What clients say</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl">
          Results that speak for themselves.
        </h2>
      </div>
      <div class="mt-12 grid gap-5 grid-cols-1 sm:grid-cols-2 md:grid-cols-3">
        {
          testimonials.map((t) => (
            <figure class="flex flex-col rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
              <div class="flex gap-1" aria-hidden="true">
                {[0, 1, 2, 3, 4].map(() => (
                  <svg class="h-4 w-4 text-brand" viewBox="0 0 20 20" fill="currentColor">
                    <path d="M10 1.5l2.6 5.3 5.9.9-4.3 4.1 1 5.8L10 14.9l-5.2 2.7 1-5.8L1.5 7.7l5.9-.9z" />
                  </svg>
                ))}
              </div>
              <blockquote class="mt-4 flex-1 leading-relaxed text-slate-700">
                &ldquo;{t.quote}&rdquo;
              </blockquote>
              <figcaption class="mt-5 border-t border-slate-100 pt-4">
                <p class="text-sm font-semibold text-ink">{t.name}</p>
                <p class="text-sm text-slate-500">{t.company}</p>
              </figcaption>
            </figure>
          ))
        }
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="border-t border-slate-200 bg-white py-20 md:py-28">
    <div class="mx-auto max-w-3xl px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="text-sm font-semibold uppercase tracking-widest text-brand">Questions</p>
        <h2 class="mt-3 text-3xl font-bold tracking-tight text-ink md:text-4xl">
          Search &amp; AI visibility, answered.
        </h2>
      </div>
      <div class="mt-12 space-y-3">
        {
          faqs.map((f) => (
            <details class="group rounded-2xl border border-slate-200 bg-slate-50 p-6 [&_summary::-webkit-details-marker]:hidden">
              <summary class="flex cursor-pointer items-center justify-between gap-4 text-left font-semibold text-ink">
                {f.q}
                <svg class="h-5 w-5 flex-none text-brand transition group-open:rotate-45" viewBox="0 0 20 20" fill="none">
                  <path d="M10 4v12M4 10h12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" />
                </svg>
              </summary>
              <p class="mt-4 leading-relaxed text-slate-600" set:html={f.a} />
            </details>
          ))
        }
      </div>
    </div>
  </section>

  <script type="application/ld+json" set:html={faqJsonLd} />

  <!-- CTA -->
  <section class="glow relative overflow-hidden bg-ink py-24 md:py-32">
    <div class="relative mx-auto max-w-3xl px-6 text-center">
      <h2 class="text-3xl font-extrabold tracking-tight text-white md:text-5xl">
        Let's get you found.
      </h2>
      <p class="mx-auto mt-6 max-w-xl text-lg leading-relaxed text-white/70">
        Tell me where you want to grow and I'll show you the fastest path to more
        of the right customers, across search and AI.
      </p>
      <div class="mt-9 flex flex-wrap items-center justify-center gap-4">
        <a
          href="/contact"
          class="inline-flex items-center gap-2 rounded-full bg-white px-7 py-3.5 text-base font-semibold text-ink shadow-xl shadow-black/20 transition hover:bg-white/90"
        >
          Send me a message
          <svg class="h-4 w-4" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </a>
        <a href="/" class="text-sm font-semibold text-white/70 transition hover:text-white">
          Back to home &rarr;
        </a>
      </div>
    </div>
  </section>

  <!-- FOOTER -->
  <footer class="bg-ink-soft py-12 text-white/60">
    <div class="mx-auto flex max-w-6xl flex-col items-center justify-between gap-6 px-6 sm:flex-row">
      <div class="flex items-center text-white">
        <div>
          <img src="/logo.png" alt={SITE.brand} class="h-12 w-auto" />
          <p class="mt-2 text-xs leading-tight text-white/50">{SITE.role}</p>
        </div>
      </div>
      <nav class="flex gap-6 text-sm">
        <a href="/#audit" class="transition hover:text-white">The Audit</a>
        <a href="/search-visibility" class="transition hover:text-white">Search &amp; Visibility</a>
        <a href="/#faq" class="transition hover:text-white">FAQ</a>
        <a href="/contact" class="transition hover:text-white">Contact</a>
      </nav>
    </div>
    <p class="mt-8 text-center text-xs text-white/40">
      © {new Date().getFullYear()} {SITE.brand}. {SITE.location}.
    </p>
  </footer>
</Layout>
